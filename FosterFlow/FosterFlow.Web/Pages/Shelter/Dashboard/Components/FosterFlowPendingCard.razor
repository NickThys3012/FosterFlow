<div class="pending-card">
    <div class="pending-avatar">👤</div>
    <div class="pending-info">
        <div class="pending-name">@FostersName → @CatName</div>
        <div class="pending-sub">@HomeType · @DogField · @UrgentField · @Experience</div>
    </div>
    <div class="pending-actions">
        <!-- TODO in a later ticket I'll add the logic behind this-->
        <button type="button" class="btn btn-sm btn-success" aria-label="Accept match request">✓</button>
        <button type="button" class="btn btn-sm btn-danger" aria-label="Decline match request">✕</button>
    </div>
</div>