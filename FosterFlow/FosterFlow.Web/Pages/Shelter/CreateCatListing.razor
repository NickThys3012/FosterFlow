@page "/Shelter/CreateCatListing"
@using FosterFlow.Domain.Enums
@using FosterFlow.Web.Components
@using FosterFlow.Web.Shared
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Shelter")]

<div class="listing-shell">
    <div class="listing-card">
        <div class="listing-card__header">
            <div class="listing-card__brand">
                <span class="listing-card__brand-icon">🐾</span>
                <span class="listing-card__brand-name">FosterFlow</span>
            </div>
            <a class="listing-card__back" href="/Shelter/Dashboard">← Back to dashboard</a>
        </div>

        <div class="listing-card__body">
            <FosterFlowImageUpload @bind-PhotoUrl="_photoUrl"
                                   Title="Tap to upload a photo of the cat"
                                   Hint="JPG, PNG up to 10MB"/>

            <div class="form-row">
                <FosterFlowInput Label="Cat's name" Placeholder="Luna" @bind-Value="_catName"/>
                <FosterFlowInput Label="Age" Placeholder="6 months" @bind-Value="_age"/>
            </div>


            <div class="form-row" style="grid-template-columns: 1fr 1fr">
                <FosterFlowSelect TValue="Sex"
                                  Value="_sex"
                                  ValueChanged="@(value => _sex = value)"
                                  Label="Sex"
                                  Icon="ti-heart"
                                  Options="FfDropdownOption.FromEnum<Sex>()"/>
                <FosterFlowInput Label="Foster duration" Placeholder="3 weeks" @bind-Value="_fosterDuration"/>
            </div>

            <FosterFlowTagInput @bind-Values="_temperamentTags"
                                Label="Temperament tags"
                                Hint="Help fosters understand the cat's personality"/>

            <FosterFlowInput Label="Medical needs" Placeholder="Daily eye drops · Neutered" @bind-Value="_medicalNeeds"/>
            <FosterFlowToggle Label="⚡ Mark as urgent" SubLabel="This cat is at risk and needs a foster immediately" @bind-Value="_isUrgent" ShowDivider="true"/>
            <FosterFlowToggle Label="🐶 Dog-friendly home OK" SubLabel="Foster can have dogs in the home" @bind-Value="_dogFriendly"/>
            <button class="btn btn-full listing-card__submit" type="button">Post listing →</button>
        </div>
    </div>
</div>
