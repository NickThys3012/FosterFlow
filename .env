# Local development configuration for docker-compose.
# This file is read automatically by `docker compose`. It is gitignored — copy
# .env.example to .env and adjust as needed. Do NOT commit real secrets.

# Host port the API is published on (maps to container port 8080).
API_PORT=5000

# Database
DB_NAME=FosterFlow
DB_SA_PASSWORD=Your_Strong_Passw0rd!

# JWT (must be at least 32 characters)
JWT_SECRET=local-development-jwt-secret-change-me-please-32+chars
JWT_ISSUER=FosterFlow.Server
JWT_AUDIENCE=FosterFlow.Client
