# Template for local development configuration used by docker-compose.
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# The .env file is gitignored so your local secrets stay out of version control.

# Host port the API is published on (maps to container port 8080).
API_PORT=5000

# Database
DB_NAME=FosterFlow
DB_SA_PASSWORD=Your_Strong_Passw0rd!

# JWT (must be at least 32 characters)
JWT_SECRET=local-development-jwt-secret-change-me-please-32+chars
JWT_ISSUER=FosterFlow.Server
JWT_AUDIENCE=FosterFlow.Client

# Monitoring stack host ports (US-INF-4.1/4.2/4.3)
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
