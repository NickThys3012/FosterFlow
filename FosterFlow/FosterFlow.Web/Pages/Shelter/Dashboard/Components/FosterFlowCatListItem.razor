@using FosterFlow.Domain.Enums
@using FosterFlow.Web.Components
<div class="cat-row">
    <div class="cat-row-photo">
        @if (!string.IsNullOrWhiteSpace(PhotoUrl))
        {
            <img class="cat-row-photo-image" src="@PhotoUrl" alt="Photo of @Name"/>
        }
        else
        {
            <span class="cat-row-photo-fallback">🐱</span>
        }
    </div>
    <div class="cat-row-info">
        <div class="cat-row-name">@Name</div>
        <div class="cat-row-meta">@MetaText</div>
        <div class="cat-row-badge">
            @if (IsUrgent)
            {
                <FosterFlowBadge IsUrgent="true"/>
            }
            @if (Status is CatStatus.UpForFostering or CatStatus.Matched or CatStatus.Pending)
            {
                <FosterFlowBadge Status="Status"/>
            }
        </div>
    </div>
    <div class="cat-row-actions">
        <!-- TODO add redirect to dedicated page #83 -->
        <button class="btn btn-outline" @onclick="RedirectToCatUpdate">Update</button>
        <button class="@ActionButtonClass" @onclick="RedirectToCatDetail">@ActionButtonText</button>
    </div>
</div>