@page "/Shelter/Dashboard"
@using FosterFlow.Web.Components
@using FosterFlow.Web.Pages.Shelter.Dashboard.Components
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Shelter")]
<div class="body-pad">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;">
        <div>
            <div class="shelter-dashboard--title">Hello @UserName 👋</div>
            <div class="shelter-dashboard--subtitle">You have @PendingCats.Count pending match requests</div>
        </div>
        <button class="btn btn-sm" @onclick="CreateListing">+ Add cat</button>
    </div>

    <div class="dash-stats">
        <FosterFlowStatCard StatNum="@_cats.Cats.Count" StatLabel="Active cats"/>
        <FosterFlowStatCard StatNum="@PendingCats.Count" StatLabel="Pending" StatColor="#b7791f"/>
        <FosterFlowStatCard StatNum="@MatchedCats.Count" StatLabel="Matched" StatColor="var(--ff-green)"/>
    </div>

    <FosterFlowSection>
        <TitleContent>
            Your cats <small>@_cats.Cats.Count active</small>
        </TitleContent>
    </FosterFlowSection>

    <!-- no pagination for now -->
    @if (_cats.Cats.Count == 0)
    {
        <div class="shelter-dashboard--subtitle">No cats</div>
    }
    else
    {
        <div class="cat-list">
            @foreach (var cat in _cats.Cats)
            {
                <FosterFlowCatListItem Id="@cat.Id" Name="@cat.CatName" Age="@cat.Age" Sex="@cat.Sex"
                                       WeeksNeeded="@cat.WeeksNeeded"
                                       IsUrgent="@cat.IsUrgent" Matches="@cat.Matches" Status="@cat.Status"
                                       PhotoUrl="@cat.PhotoUrl"/>
            }
        </div>
    }

    <div class="pending-section">
        <FosterFlowSection>
            <TitleContent>
                Pending requests <small>@PendingCats.Count requests</small>
            </TitleContent>
        </FosterFlowSection>

        @if (PendingCats.Count == 0)
        {
            <div class="shelter-dashboard--subtitle">No pending requests right now</div>
        }
        else
        {
            @foreach (var cat in PendingCats)
            {
                <FosterFlowPendingCard FostersName="@cat.FostersName" CatName="@cat.CatName" HomeType="@cat.HomeType"
                                       HasDogs="@cat.HasDogs" IsUrgent="@cat.IsUrgent"
                                       Experience="@cat.ExperienceLevel"/>
            }
        }
    </div>
</div>
