@* Usage: <FosterFlowToggle @bind-Value="isUrgent" Label="Mark as urgent" SubLabel="Shown to fosters" /> *@

<div class="ff-toggle-row @(ShowDivider ? "with-divider" : "")">
    <div class="ff-toggle-copy">
        <div class="ff-toggle-label">@Label</div>
        @if (!string.IsNullOrEmpty(SubLabel))
        {
            <div class="ff-toggle-sub">@SubLabel</div>
        }@if (ShowWarningWhenTrue && Value)
         {
             <div class="ff-toggle-sub" style="color:  var(--ff-red);">@Warning</div>
         }
    </div>
    <button type="button"
            class="ff-toggle @(Value ? "" : "off")"
            role="switch"
            aria-checked="@Value.ToString().ToLower()"
            aria-label="@Label"
            disabled="@Disabled"
            @onclick="Toggle">
        <span class="sr-only">@(Value ? "On" : "Off")</span>
    </button>
</div>